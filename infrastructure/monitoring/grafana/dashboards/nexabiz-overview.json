{
  "title": "NexaBiz ERP Overview",
  "uid": "nexabiz-overview",
  "version": 1,
  "schemaVersion": 38,
  "tags": [
    "nexabiz",
    "erp"
  ],
  "panels": [
    {
      "id": 1,
      "title": "Sales Today",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(nexabiz_sales_total)",
          "legendFormat": "Sales Today"
        }
      ]
    },
    {
      "id": 2,
      "title": "Active Services",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "targets": [
        {
          "expr": "count(up{job=~\"nexabiz.*\"} == 1)",
          "legendFormat": "Up"
        }
      ]
    },
    {
      "id": 3,
      "title": "API Request Rate",
      "type": "graph",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "rate(nexabiz_http_requests_total[5m])",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Service Health",
      "type": "table",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "expr": "up{job=~\"nexabiz.*\"}",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "HTTP Error Rate",
      "type": "graph",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "expr": "rate(nexabiz_http_requests_total{status=~\"5..\"}[5m])",
          "legendFormat": "Errors"
        }
      ]
    },
    {
      "id": 6,
      "title": "P95 Response Time",
      "type": "graph",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(nexabiz_http_duration_ms_bucket[5m]))",
          "legendFormat": "P95 ms"
        }
      ]
    }
  ]
}