# =============================================================
# NexaBiz ERP — Environment Variables Template
# Copy to .env and fill in values. NEVER commit .env to git.
# =============================================================

# --- Application ---
NODE_ENV=development
APP_URL=http://localhost:5173
API_GATEWAY_URL=http://localhost:8000

# --- Auth Service ---
JWT_SECRET=CHANGE_ME_VERY_LONG_SECRET_AT_LEAST_64_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_FROM_ABOVE
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# --- PostgreSQL Databases ---
ACCOUNTING_DB_URL=postgresql://nexabiz:nexabiz@localhost:5432/nexabiz_accounting
SALES_DB_URL=postgresql://nexabiz:nexabiz@localhost:5432/nexabiz_sales
INVENTORY_DB_URL=postgresql://nexabiz:nexabiz@localhost:5432/nexabiz_inventory
HR_DB_URL=postgresql://nexabiz:nexabiz@localhost:5432/nexabiz_hr
CRM_DB_URL=postgresql://nexabiz:nexabiz@localhost:5432/nexabiz_crm
BANKING_DB_URL=postgresql://nexabiz:nexabiz@localhost:5432/nexabiz_banking
PROCUREMENT_DB_URL=postgresql://nexabiz:nexabiz@localhost:5432/nexabiz_procurement
PROJECT_DB_URL=postgresql://nexabiz:nexabiz@localhost:5432/nexabiz_projects
WORKFLOW_DB_URL=postgresql://nexabiz:nexabiz@localhost:5432/nexabiz_workflow
CONFIG_DB_URL=postgresql://nexabiz:nexabiz@localhost:5432/nexabiz_config
AUTH_DB_URL=postgresql://nexabiz:nexabiz@localhost:5432/nexabiz_auth

# --- MongoDB (Event Store) ---
MONGODB_URL=mongodb://nexabiz:nexabiz@localhost:27017/nexabiz_events

# --- ClickHouse (Analytics) ---
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DB=nexabiz_analytics
CLICKHOUSE_USER=nexabiz
CLICKHOUSE_PASSWORD=CHANGE_ME

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Kafka ---
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=nexabiz
KAFKA_GROUP_ID=nexabiz-consumers

# --- Elasticsearch ---
ELASTICSEARCH_URL=http://localhost:9200

# --- AWS / MinIO (File Storage) ---
S3_BUCKET=nexabiz-files
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
# For self-hosted MinIO:
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=nexabiz
MINIO_SECRET_KEY=CHANGE_ME

# --- HashiCorp Vault ---
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=CHANGE_ME

# --- Exchange Rates API ---
EXCHANGE_RATES_API_KEY=CHANGE_ME
EXCHANGE_RATES_API_URL=https://openexchangerates.org/api

# --- Email (SMTP) ---
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=CHANGE_ME
SMTP_FROM=noreply@nexabiz.com

# --- SMS ---
TWILIO_ACCOUNT_SID=CHANGE_ME
TWILIO_AUTH_TOKEN=CHANGE_ME
TWILIO_FROM_NUMBER=+1234567890

# --- Payment Gateways ---
STRIPE_SECRET_KEY=CHANGE_ME
PAYNOW_INTEGRATION_ID=CHANGE_ME
PAYNOW_INTEGRATION_KEY=CHANGE_ME
FLUTTERWAVE_SECRET_KEY=CHANGE_ME

# --- AI Service ---
OPENAI_API_KEY=CHANGE_ME

# --- Monitoring ---
SENTRY_DSN=CHANGE_ME
PROMETHEUS_PORT=9090

# --- Feature Flags ---
UNLEASH_URL=http://localhost:4242
UNLEASH_CLIENT_KEY=CHANGE_ME
